{
	"name": "monitor-pro",
	"displayName": "Monitor Pro",
	"description": "Monitor all the resources you care about.",
	"publisher": "nexmoe",
	"keywords": [
		"performance",
		"resource",
		"resources",
		"monitor",
		"memory",
		"cpu",
		"io",
		"network",
		"disk",
		"storage"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/nexmoe/vscode-monitor-pro"
	},
	"icon": "assets/icon.png",
	"version": "0.6.3",
	"engines": {
		"vscode": "^1.104.1"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"l10n": "./l10n",
	"scripts": {
		"vscode:prepublish": "pnpm run package",
		"check-types": "pnpm tsc --noEmit",
		"compile": "pnpm run check-types && node esbuild.js",
		"compile-tests": "pnpm tsc -p . --outDir out",
		"deploy": "vsce publish --no-dependencies",
		"gen-l10n": "npx @vscode/l10n-dev export -o ./l10n ./src",
		"lint": "eslint src --ext ts",
		"package": "pnpm run check-types && node esbuild.js --production",
		"package:vsix": "vsce package --no-dependencies",
		"pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
		"test": "node ./out/test/runTest.js",
		"watch": "npm-run-all -p watch:*",
		"watch-tests": "tsc -p . -w --outDir out",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json"
	},
	"devDependencies": {
		"@types/mocha": "10.0.10",
		"@types/node": "18.19.127",
		"@types/vscode": "1.104.0",
		"@typescript-eslint/eslint-plugin": "6.21.0",
		"@typescript-eslint/parser": "6.21.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/test-electron": "2.5.2",
		"@vscode/vsce": "^3.2.0",
		"esbuild": "^0.25.9",
		"eslint": "8.57.1",
		"glob": "10.4.5",
		"mocha": "10.8.2",
		"npm-run-all2": "5.0.2",
		"typescript": "5.9.2"
	},
	"dependencies": {
		"systeminformation": "5.31.6"
	},
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "monitor-pro",
					"title": "%viewContainer.monitor-pro.title%",
					"icon": "assets/icon.png"
				}
			]
		},
		"views": {
			"monitor-pro": [
				{
					"icon": "$(graph-line)",
					"type": "webview",
					"id": "monitor-pro.taskManager",
					"name": "%views.taskManager%"
				}
			]
		},
		"commands": [
			{
				"command": "monitor-pro.focusTaskManager",
				"title": "%command.focusTaskManager%"
			}
		],
		"configuration": {
			"title": "Monitor Pro",
			"properties": {
				"monitor-pro.metrics": {
					"type": "array",
					"items": {
						"type": "string",
						"enum": [
							"cpu",
							"memoryActive",
							"memoryUsed",
							"network",
							"fileSystem",
							"battery",
							"cpuTemp",
							"cpuSpeed",
							"osDistro",
							"diskSpace",
							"uptime"
						]
					},
					"default": [
						"cpu",
						"memoryActive",
						"memoryUsed",
						"network",
						"fileSystem",
						"battery",
						"cpuTemp",
						"cpuSpeed",
						"osDistro",
						"diskSpace",
						"uptime"
					],
					"description": "%config.metrics%"
				},
				"monitor-pro.refresh-interval": {
					"type": "number",
					"default": 2000,
					"description": "%config.refresh-interval%"
				},
				"monitor-pro.diskSpace": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"all",
						"C:"
					],
					"description": "%config.diskSpace%"
				}
			}
		}
	}
}
